include ./work.conf
include ./devices.conf
include ./startup.conf
include ./local.conf

# This file has been auto-generated by i3-config-wizard(1).
# It will not be overwritten, so edit it as you like.
#
# Should you change your keyboard layout some time, delete
# this file and re-run i3-config-wizard(1).
#

# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!
set $mod Mod4


# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:JetBrainsMono 7
focus_follows_mouse no
mouse_warping none
focus_on_window_activation smart
default_border pixel 2

include ./scratchpad.conf

# exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id xss-lock --transfer-sleep-lock -- lock

# NetworkManager is the most popular way to manage wireless networks on Linux,
# and nm-applet is a desktop environment-independent system tray GUI for it.
exec --no-startup-id nm-applet

# Audio
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +2%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -2%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle

# Brightness
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +10%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 10%-

floating_modifier $mod
tiling_drag modifier titlebar

# Terminal
bindsym $mod+backslash exec kitty
bindsym $mod+Control+backslash exec kitty -T floating
bindsym $mod+Return exec rofi -show drun
bindsym $mod+Shift+Return exec rofi -show run

bindsym $mod+Shift+q kill
bindsym $mod+Shift+w exec rofi -show window

# Focus - vim
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Focus - wasd
bindsym $mod+a focus left
bindsym $mod+s focus down
bindsym $mod+w focus up
bindsym $mod+d focus right

bindsym --whole-window --border $mod+button4 focus left
bindsym --whole-window --border $mod+button5 focus right

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Focus output
bindsym $mod+Shift+h focus output left
bindsym $mod+Shift+j focus output down
bindsym $mod+Shift+k focus output up
bindsym $mod+Shift+l focus output right
bindsym $mod+Shift+Left focus output left
bindsym $mod+Shift+Down focus output down
bindsym $mod+Shift+Up focus output up
bindsym $mod+Shift+Right focus output right

# Move
bindsym $mod+Control+h move left
bindsym $mod+Control+j move down
bindsym $mod+Control+k move up
bindsym $mod+Control+l move right
bindsym $mod+Control+Left move left
bindsym $mod+Control+Down move down
bindsym $mod+Control+Up move up
bindsym $mod+Control+Right move right

# Move to output
bindsym $mod+Control+Shift+h move container to output left
bindsym $mod+Control+Shift+j move container to output down
bindsym $mod+Control+Shift+k move container to output up
bindsym $mod+Control+Shift+l move container to output right
bindsym $mod+Control+Shift+Left move container to output left
bindsym $mod+Control+Shift+Down move container to output down
bindsym $mod+Control+Shift+Up move container to output up
bindsym $mod+Control+Shift+Right move container to output right

# Split
bindsym $mod+b split h
bindsym $mod+v split v

bindsym $mod+f fullscreen toggle

# Layout
bindsym $mod+z layout stacking
bindsym $mod+x layout tabbed
bindsym $mod+c layout toggle split

# Tiling / floating
bindsym $mod+Shift+space floating toggle
bindsym $mod+Shift+f floating toggle
bindsym $mod+space focus mode_toggle

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Move to workspace
bindsym $mod+Control+1 move container to workspace number $ws1 workspace $ws1
bindsym $mod+Control+2 move container to workspace number $ws2 workspace $ws2
bindsym $mod+Control+3 move container to workspace number $ws3 workspace $ws3
bindsym $mod+Control+4 move container to workspace number $ws4 workspace $ws4
bindsym $mod+Control+5 move container to workspace number $ws5 workspace $ws5
bindsym $mod+Control+6 move container to workspace number $ws6 workspace $ws6
bindsym $mod+Control+7 move container to workspace number $ws7 workspace $ws7
bindsym $mod+Control+8 move container to workspace number $ws8 workspace $ws8
bindsym $mod+Control+9 move container to workspace number $ws9 workspace $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10 workspace $ws10

# Reload / restart / exit
bindsym $mod+Shift+r reload
bindsym $mod+Shift+c restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

# Resize
set $resize_delta 5

mode "resize" {
  bindsym h exec "i3-msg resize grow left $resize_delta px or $resize_delta ppt || i3-msg resize shrink right $resize_delta px or $resize_delta ppt"
  bindsym l exec "i3-msg resize grow right $resize_delta px or $resize_delta ppt || i3-msg resize shrink left $resize_delta px or $resize_delta ppt"
  bindsym j exec "i3-msg resize grow down $resize_delta px or $resize_delta ppt || i3-msg resize shrink up $resize_delta px or $resize_delta ppt"
  bindsym k exec "i3-msg resize grow up $resize_delta px or $resize_delta ppt || i3-msg resize shrink down $resize_delta px or $resize_delta ppt"

  bindsym Left exec "i3-msg resize grow left $resize_delta px or $resize_delta ppt || i3-msg resize shrink right $resize_delta px or $resize_delta ppt"
  bindsym Right exec "i3-msg resize grow right $resize_delta px or $resize_delta ppt || i3-msg resize shrink left $resize_delta px or $resize_delta ppt"
  bindsym Up exec "i3-msg resize grow up $resize_delta px or $resize_delta ppt || i3-msg resize shrink down $resize_delta px or $resize_delta ppt"
  bindsym Down exec "i3-msg resize grow down $resize_delta px or $resize_delta ppt || i3-msg resize shrink up $resize_delta px or $resize_delta ppt"

  bindsym Shift+h resize shrink width $resize_delta px or $resize_delta ppt
  bindsym Shift+j resize grow height $resize_delta px or $resize_delta ppt
  bindsym Shift+k resize shrink height $resize_delta px or $resize_delta ppt
  bindsym Shift+l resize grow width $resize_delta px or $resize_delta ppt

  bindsym Shift+Left resize shrink width $resize_delta px or $resize_delta ppt
  bindsym Shift+Down resize grow height $resize_delta px or $resize_delta ppt
  bindsym Shift+Up resize shrink height $resize_delta px or $resize_delta ppt
  bindsym Shift+Right resize grow width $resize_delta px or $resize_delta ppt

  bindsym Return mode "default"
  bindsym Escape mode "default"
  bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

# Screenshots
bindsym Print exec --no-startup-id maim | xclip -selection clipboard -t image/png
bindsym $mod+Shift+s exec --no-startup-id maim --select | xclip -selection clipboard -t image/png

# Move workspace to output
bindsym $mod+Ctrl+greater move workspace to output right
bindsym $mod+Ctrl+less move workspace to output left

# Misc
bindsym Alt+Shift+1 exec obs-recording-toggle.sh

for_window [class="kitty"] border pixel 0
for_window [class="Alacritty"] border pixel 0
for_window [class="st-256color"] border pixel 0

for_window [class="neovide"] focus
for_window [class="neovide"] border pixel 0 
assign [class="neovide"] 3

for_window [class="Code"] focus
for_window [class="Code"] border pixel 0
assign [class="Code"] 3

assign [class="TelegramDesktop"] 4
for_window [class="TelegramDesktop"] layout tabbed

assign [class="discord"] 4
for_window [class="discord"] layout tabbed

assign [class="zoom"] 7
for_window [class="zoom"] layout tabbed


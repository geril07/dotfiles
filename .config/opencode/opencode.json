{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "model": "openrouter/x-ai/grok-code-fast-1",
  "share": "disabled",
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{file:~/.secrets/OPENROUTER_API_KEY}"
      }
    }
  },
  "disabled_providers": ["opencode"],
  "keybinds": {
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d"
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "small_model": "openrouter/google/gemini-3.1-flash-lite",
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "~/.local/share/rtk/**": "allow",
      "~/.agents/skills/**": "allow",
      "~/.cache/opencode/packages/oh-my-openagent@latest/**": "allow",
    },
    "edit": {
      "~/.agents/skills/**": "ask",
    },
    "bash": {
      "*": "allow",
    },
  },
  "disabled_providers": [],
  "plugin": [
    "@mohak34/opencode-notifier",
    "opencode-with-claude",
    "opencode-mystatus",
    "oh-my-opencode-slim",
    "@plannotator/opencode",
    // "@dietrichgebert/ponytail",
  ],
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification.",
    },
  },
  "agent": {
    "general": {
      "disable": false,
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "disable": false,
    },
    "deepseek-v4-flash": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
    },
    "deepseek-v4-pro": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max",
    },
    "mimo-v2.5-pro": {
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5-pro",
      "variant": "high",
    },
    "minimax-m3": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "variant": "thinking",
    },
    "orch-explore": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "",
      "variant": "max",
    },
    "orch-implement": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
      "description": "",
    },
    "orch-review": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "variant": "thinking",
      "description": "",
    },
  },
  "formatter": {
    "gofmt": {
      "disabled": false,
    },
    "mix": {
      "disabled": true,
    },
    "prettier": {
      "disabled": false,
    },
    "biome": {
      "disabled": true,
    },
    "zig": {
      "disabled": true,
    },
    "clang-format": {
      "disabled": true,
    },
    "ktlint": {
      "disabled": true,
    },
    "ruff": {
      "disabled": true,
    },
    "rubocop": {
      "disabled": true,
    },
    "standardrb": {
      "disabled": true,
    },
    "htmlbeautifier": {
      "disabled": true,
    },
  },
  "lsp": {
    "typescript": {
      "disabled": true,
    },
    "eslint": {
      "disabled": true,
    },
    "gopls": {
      "disabled": true,
    },
    "ruby-lsp": {
      "disabled": true,
    },
    "pyright": {
      "disabled": true,
    },
    "elixir-ls": {
      "disabled": true,
    },
    "zls": {
      "disabled": true,
    },
    "csharp": {
      "disabled": true,
    },
    "vue": {
      "disabled": true,
    },
    "rust": {
      "disabled": true,
    },
    "clangd": {
      "disabled": true,
    },
    "svelte": {
      "disabled": true,
    },
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true,
    },
    "btca-local": {
      "type": "local",
      "command": ["npx", "-g", "-y", "btca", "mcp"],
      "enabled": false,
    },
    "context7": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-g", "-y", "@upstash/context7-mcp"],
    },
    "figma-mcp": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-g", "-y", "figma-developer-mcp", "--stdio"],
    },
    "grep-app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
    },
    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-g", "-y", "chrome-devtools-mcp@latest"],
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--isolated",
        "--browser=chromium",
      ],
      "enabled": false,
    },
  },
  "provider": {
    "ollama": {
      "models": {
        "qwen3.5:4b": {
          "name": "qwen3.5:4b",
        },
        "qwen3.5:9b": {
          "name": "qwen3.5:9b",
        },
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
      },
    },
    "anthropic": {
      "options": {
        "baseURL": "http://127.0.0.1:3456",
        "apiKey": "dummy",
      },
    },
    "google": {
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}",
      },
    },
    "deepseek": {
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}",
      },
    },
    "ollama-cloud": {
      "options": {
        "apiKey": "{env:OLLAMA_CLOUD_API_KEY}",
      },
      "whitelist": [
        "glm-5.2",
        "minimax-m3",
        "kimi-k2.7-code",
        "kimi-k2.6",
        "deepseek-v4-pro",
        "deepseek-v4-flash",
      ],
    },
    "cursor-acp": {
      "name": "Cursor ACP",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1",
      },
      "models": {
        "cursor-acp/auto": {
          "name": "Auto",
        },
        "cursor-acp/claude-opus-4-7": {
          "name": "Claude 4.7 Opus",
        },
        "cursor-acp/claude-4.6-sonnet": {
          "name": "Claude 4.6 Sonnet",
        },
        "cursor-acp/claude-4.5-haiku": {
          "name": "Claude 4.5 Haiku",
        },
        "cursor-acp/gpt-5.5": {
          "name": "GPT-5.5",
        },
        "cursor-acp/gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro",
        },
        "cursor-acp/composer-2.5": {
          "name": "Composer 2.5",
        },
        "cursor-acp/composer-2.5-fast": {
          "name": "Composer 2.5 Fast",
        },
      },
    },
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}",
      },
      "models": {
        "z-ai/glm-5.2": {
          "options": {
            "provider": {
              "order": ["z-ai/fp8"],
              "allow_fallbacks": false,
            },
          },
        },
        "moonshotai/kimi-k2.6": {
          "options": {
            "provider": {
              "order": ["moonshotai/int4"],
              "allow_fallbacks": false,
            },
          },
        },
        "minimax/minimax-m2.7": {
          "options": {
            "provider": {
              "only": ["minimax/fp8"],
              "order": ["minimax/fp8"],
              "allow_fallbacks": false,
            },
          },
        },
        "google/gemini-3.1-flash-lite-preview": {
          "options": {
            "provider": {
              "order": ["google-ai-studio"],
              "allow_fallbacks": false,
            },
          },
        },
        "google/gemini-3.1-flash-lite": {
          "options": {
            "provider": {
              "order": ["google-ai-studio"],
              "allow_fallbacks": false,
            },
          },
        },
        "google/gemini-3-flash-preview": {
          "options": {
            "provider": {
              "order": ["google-ai-studio"],
              "allow_fallbacks": false,
            },
          },
        },
        "google/gemini-3-pro-preview": {
          "options": {
            "provider": {
              "order": ["google-ai-studio"],
              "allow_fallbacks": false,
            },
          },
        },
        "openai/gpt-oss-120b": {
          "options": {
            "provider": {
              "require_parameters": true,
              "order": ["fireworks", "groq"],
              "allow_fallbacks": false,
            },
          },
        },
        "openai/gpt-oss-20b": {
          "options": {
            "provider": {
              "order": ["groq"],
              "allow_fallbacks": false,
            },
          },
        },
      },
    },
  },
}

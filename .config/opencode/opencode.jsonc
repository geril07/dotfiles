{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  // "small_model": "openrouter/google/gemini-2.5-flash-lite",
  // "small_model": "openrouter/openai/gpt-oss-20b",
  "small_model": "openrouter/google/gemini-3.1-flash-lite",

  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "~/.local/share/rtk/**": "allow",
      "~/.agents/skills/**": "allow",
    },

    "edit": {
      "~/.agents/skills/**": "ask",
    },

    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push *": "ask",
      "git clone *": "ask",
      // "mv *": "ask",
      "rm *": "ask",
    },
  },

  "disabled_providers": [],

  "plugin": [
    "@mohak34/opencode-notifier@0.2.5",
    "opencode-with-claude@latest",
    "oh-my-openagent@latest"
  ],

  "agent": {
    "gemini-flash-agent": {
      "mode": "subagent",
      "model": "openrouter/google/gemini-3-flash-preview",
    },

    "gemini-flash-lite-agent": {
      "mode": "subagent",
      "model": "openrouter/google/gemini-3.1-flash-lite-preview",
      "variant": "high",
    },

    "deepseek-flash-agent": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
    },

    "deepseek-pro-agent": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max",
    },

    "gpt-5.4-mini-agent": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
    },
  },

  "formatter": {
    "gofmt": { "disabled": false },
    "mix": { "disabled": true },
    "prettier": { "disabled": false },
    "biome": { "disabled": true },
    "zig": { "disabled": true },
    "clang-format": { "disabled": true },
    "ktlint": { "disabled": true },
    "ruff": { "disabled": true },
    "rubocop": { "disabled": true },
    "standardrb": { "disabled": true },
    "htmlbeautifier": { "disabled": true },
  },

  "lsp": {
    "typescript": { "disabled": true },
    "eslint": { "disabled": true },
    "gopls": { "disabled": true },
    "ruby-lsp": { "disabled": true },
    "pyright": { "disabled": true },
    "elixir-ls": { "disabled": true },
    "zls": { "disabled": true },
    "csharp": { "disabled": true },
    "vue": { "disabled": true },
    "rust": { "disabled": true },
    "clangd": { "disabled": true },
    "svelte": { "disabled": true },
  },

  "mcp": {
    "btca-local": {
      "type": "local",
      "command": ["npx", "-g", "-y", "btca", "mcp"],
      "enabled": false,
    },
    "context7": {
      // "type": "remote",
      // "url": "https://mcp.context7.com/mcp",
      "enabled": false,
      "type": "local",
      "command": ["npx", "-g", "-y", "@upstash/context7-mcp"],
    },
    "figma-mcp": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-g", "-y", "figma-developer-mcp", "--stdio"],
    },

    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-g", "-y", "chrome-devtools-mcp@latest"],
    },

    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--isolated",
        "--browser=chromium",
      ],
      "enabled": false,
    },
  },

  "provider": {
    "ollama": {
      "models": {
        "qwen3.5:4b": {
          "name": "qwen3.5:4b",
        },

        "qwen3.5:9b": {
          "name": "qwen3.5:9b",
        },
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
      },
    },

    "anthropic": {
      "options": {
        "baseURL": "http://127.0.0.1:3456",
        "apiKey": "dummy",
      },
    },

    "google": {
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}",
      },
    },

    "deepseek": {
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}",
      },
    },
    "cursor-acp": {
      "name": "Cursor ACP",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1",
      },
      "models": {
        "cursor-acp/auto": { "name": "Auto" },

        "cursor-acp/claude-opus-4-7": { "name": "Claude 4.7 Opus" },
        "cursor-acp/claude-4.6-sonnet": { "name": "Claude 4.6 Sonnet" },
        "cursor-acp/claude-4.5-haiku": { "name": "Claude 4.5 Haiku" },

        "cursor-acp/gpt-5.5": { "name": "GPT-5.5" },

        "cursor-acp/gemini-3.1-pro": { "name": "Gemini 3.1 Pro" },

        "cursor-acp/composer-2.5": { "name": "Composer 2.5" },
        "cursor-acp/composer-2.5-fast": { "name": "Composer 2.5 Fast" },
      },
    },

    "openrouter": {
      // "npm": "@openrouter/ai-sdk-provider",

      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}",
      },

      "models": {
        "moonshotai/kimi-k2.6": {
          "options": {
            "provider": {
              "order": ["moonshotai/int4"],
              "allow_fallbacks": false,
            },
          },
        },

        "minimax/minimax-m2.7": {
          "options": {
            "provider": {
              "only": ["minimax/fp8"],
              "order": ["minimax/fp8"],
              "allow_fallbacks": false,
            },
          },
        },

        "google/gemini-3.1-flash-lite-preview": {
          "options": {
            "provider": {
              "order": ["google-ai-studio"],
              "allow_fallbacks": false,
            },
          },
        },

        "google/gemini-3.1-flash-lite": {
          "options": {
            "provider": {
              "order": ["google-ai-studio"],
              "allow_fallbacks": false,
            },
          },
        },

        "google/gemini-3-flash-preview": {
          "options": {
            "provider": {
              "order": ["google-ai-studio"],
              "allow_fallbacks": false,
            },
          },
        },

        "google/gemini-3-pro-preview": {
          "options": {
            "provider": {
              "order": ["google-ai-studio"],
              "allow_fallbacks": false,
            },
          },
        },

        "openai/gpt-oss-120b": {
          "options": {
            "provider": {
              "require_parameters": true,
              "order": ["fireworks", "groq"],
              "allow_fallbacks": false,
            },
          },
        },

        "openai/gpt-oss-20b": {
          "options": {
            "provider": {
              "order": ["groq"],
              "allow_fallbacks": false,
            },
          },
        },
      },
    },
  },
}
